{
  "name": "@lance-digital/gearindigo-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for GEAR.indigo Biz - read your design documents (artifacts) via the v1 REST API with a Personal Access Token",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gearindigo-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npx tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "gearindigo",
    "design-documents",
    "anthropic"
  ],
  "author": "ランスティア株式会社 (https://biz.gearindigo.app)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lance-digital/gearindigo-mcp-server.git"
  },
  "homepage": "https://github.com/lance-digital/gearindigo-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/lance-digital/gearindigo-mcp-server/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
